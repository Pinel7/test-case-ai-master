.spinner {
    width: 40px; height: 40px;
    border: 3px solid #e0e3ed;
    border-top-color: var(--color-accent);
    border-radius: 50%;
    animation: spin .7s linear infinite;
    margin: 0 auto 12px;
}
@keyframes spin { to { transform: rotate(360deg); } }

