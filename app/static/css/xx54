.btn-ghost {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 6px 14px;
    font-size: 0.82rem;
    color: var(--color-text);
    cursor: pointer;
    display: inline-flex; align-items: center; gap: 5px;
    transition: all var(--transition);
    white-space: nowrap;
}
