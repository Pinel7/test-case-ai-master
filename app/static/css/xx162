.login-overlay-content {
    width: 100%; max-width: 400px;
    text-align: center;
    position: relative;
    z-index: 1;
    animation: loginSlideUp .8s ease .2s both;
}
@keyframes loginSlideUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
}

