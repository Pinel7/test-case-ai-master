@media (max-width: 900px) {
    .split-panel { grid-template-columns: 1fr; }
    #sidebar { width: 60px; min-width: 60px; }
    #sidebar .sidebar-title, #sidebar .nav-item span, #sidebar .nav-item small, #sidebar .sidebar-footer small, #sidebar .nav-section { display: none; }
    #sidebar .sidebar-brand { padding: 16px 12px; justify-content: center; }
    #sidebar .nav-item { align-items: center; padding: 12px; }
    #mainContent { margin-left: 60px; padding: 20px; }
    .editor-toolbar .btn-text { display: none; }
    .editor-tab { padding: 7px 10px; font-size: 0.75rem; }
    .report-charts { grid-template-columns: 1fr; }
    .card-view { grid-template-columns: 1fr; }
    .encoding-layout { grid-template-columns: 1fr; }
    .ts-layout { grid-template-columns: 1fr; }
    .rtm-stats { grid-template-columns: repeat(3, 1fr); }
    .api-test-layout { grid-template-columns: 1fr; }
}
