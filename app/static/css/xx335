.lib-batch-bar {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    padding: 6px 10px; margin-top: 6px;
    background: var(--color-accent-light);
    border: 1px solid var(--color-accent);
    border-radius: 6px;
    font-size: 0.8rem; color: var(--color-accent);
    font-weight: 500;
}
